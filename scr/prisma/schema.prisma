// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id           String       @id @default(cuid())
  name         String
  description  String?
  // Statut du pipeline asynchrone : PENDING -> PROCESSING -> COMPLETED | FAILED
  status       String       @default("PENDING")
  // Étape en cours côté serveur (pour le stepper) : AUDIO | TRANSCRIPT | ANALYSIS
  stage        String?
  // Mode stratégique de découpe choisi par l'utilisateur : punchy | standard | deep
  clipDurationMode String   @default("standard")
  // Message d'erreur en cas de FAILED
  error        String?
  // Résultat de l'analyse DeepSeek (ViralMoment[]), stocké en JSON
  viralMoments Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  videoClips   VideoClip[]
  transcripts  Transcript[]

  @@map("projects")
}

model VideoClip {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filePath    String
  duration    Float?   // in seconds
  width       Int?
  height      Int?
  fps         Float?
  fileSize    Int?     // in bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("video_clips")
}

model Transcript {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content   String   // Full transcript text
  language  String   @default("fr")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transcripts")
}